{
  "entities": {
    "StudentRecord": {
      "title": "StudentRecord",
      "description": "Student record details including personal info, academic semesters, payments and services",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "studentName": {
          "type": "string"
        },
        "fatherName": {
          "type": "string"
        },
        "phoneNumber": {
          "type": "string"
        },
        "registrationId": {
          "type": "string"
        },
        "lmsPasswordId": {
          "type": "string"
        },
        "cmsPasswordId": {
          "type": "string"
        },
        "admissionYear": {
          "type": "string"
        },
        "programSelected": {
          "type": "string"
        },
        "semesterType": {
          "type": "string",
          "enum": ["Autumn", "Spring"]
        },
        "semesters": {
          "type": "array"
        },
        "totalReceivable": {
          "type": "number"
        },
        "paymentsList": {
          "type": "array"
        },
        "serviceChargesAmount": {
          "type": "number"
        },
        "remarks": {
          "type": "string"
        },
        "serviceEnrollment": {
          "type": "boolean"
        },
        "serviceWorkshops": {
          "type": "boolean"
        },
        "serviceQuiz": {
          "type": "boolean"
        },
        "serviceAssignments": {
          "type": "boolean"
        },
        "servicePhysicalWorkshop": {
          "type": "boolean"
        },
        "serviceResearchReport": {
          "type": "boolean"
        },
        "status": {
          "type": "string",
          "enum": ["active", "completed", "suspended"]
        },
        "createdAt": {
          "type": "string"
        },
        "updatedAt": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "studentName",
        "fatherName",
        "phoneNumber",
        "registrationId",
        "lmsPasswordId",
        "cmsPasswordId",
        "admissionYear",
        "programSelected",
        "semesterType",
        "semesters",
        "totalReceivable",
        "paymentsList",
        "serviceEnrollment",
        "serviceWorkshops",
        "serviceQuiz",
        "serviceAssignments",
        "servicePhysicalWorkshop",
        "serviceResearchReport",
        "status",
        "createdAt",
        "updatedAt"
      ]
    },
    "ExamManager": {
      "title": "ExamManager",
      "description": "Information about exam managers for specific exam centres",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "centre": { "type": "string", "enum": ["Mithi", "Diplo"] },
        "totalPaidAmount": { "type": "number" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["id", "name", "phone", "email", "centre", "createdAt", "updatedAt"]
    },
    "StudentExamInfo": {
      "title": "StudentExamInfo",
      "description": "Student details for exam schedules, payment details, and dates",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "centre": { "type": "string", "enum": ["Mithi", "Diplo"] },
        "managerId": { "type": "string" },
        "courseCode": { "type": "string" },
        "studentName": { "type": "string" },
        "fatherName": { "type": "string" },
        "studentId": { "type": "string" },
        "contactNumber": { "type": "string" },
        "semesterTerm": { "type": "string" },
        "courseCodes": { "type": "array" },
        "examDates": { "type": "array" },
        "totalFee": { "type": "number" },
        "amountReceived": { "type": "number" },
        "remainingBalance": { "type": "number" },
        "paymentHistory": { "type": "array" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": [
        "id", "centre", "managerId", "courseCode", "studentName", "fatherName", 
        "studentId", "contactNumber", "semesterTerm", "courseCodes", "examDates", 
        "totalFee", "amountReceived", "remainingBalance", "paymentHistory", "createdAt", "updatedAt"
      ]
    },
    "StudentDegreeRecord": {
      "title": "StudentDegreeRecord",
      "description": "Student degree application details including payment ledgers, processing status, and tracking",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "studentName": { "type": "string" },
        "fatherName": { "type": "string" },
        "studentId": { "type": "string" },
        "contactNumber": { "type": "string" },
        "courseName": { "type": "string" },
        "category": { "type": "string", "enum": ["Normal", "Urgent"] },
        "appliedDate": { "type": "string" },
        "degreeReceivedDate": { "type": "string" },
        "status": { "type": "string", "enum": ["Applied", "Under Process", "Dispatched", "Received at Hub", "Delivered to Student"] },
        "totalFee": { "type": "number" },
        "amountReceived": { "type": "number" },
        "paymentHistory": { "type": "array" },
        "trackingNumber": { "type": "string" },
        "verificationStatus": { "type": "string", "enum": ["Pending", "Verified", "Rejected"] },
        "remarks": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": [
        "id", "studentName", "fatherName", "studentId", "contactNumber", "courseName",
        "category", "appliedDate", "status", "totalFee", "amountReceived", "paymentHistory",
        "verificationStatus", "createdAt", "updatedAt"
      ]
    },
    "StudentQuizRecord": {
      "title": "StudentQuizRecord",
      "description": "Student online quiz schedules, specific course codes, scheduled dates, and completion status",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "studentName": { "type": "string" },
        "fatherName": { "type": "string" },
        "studentId": { "type": "string" },
        "contactNumber": { "type": "string" },
        "courseCode": { "type": "string" },
        "quizDate": { "type": "string" },
        "quizDateFrom": { "type": "string" },
        "quizDateTo": { "type": "string" },
        "quizStartTime": { "type": "string" },
        "quizEndTime": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "Completed", "Overdue"] },
        "remarks": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": [
        "id", "studentName", "fatherName", "studentId", "contactNumber", "courseCode",
        "quizDate", "status", "createdAt", "updatedAt"
      ]
    },
    "ResearchProjectRecord": {
      "title": "ResearchProjectRecord",
      "description": "Student research project logs, topics, semester details, and assigned supervisor",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "semester": { "type": "string", "enum": ["Spring", "Autumn"] },
        "year": { "type": "string" },
        "studentName": { "type": "string" },
        "registrationId": { "type": "string" },
        "researchTopic": { "type": "string" },
        "topicApprovalDate": { "type": "string" },
        "supervisorName": { "type": "string" },
        "supervisorContact": { "type": "string" },
        "dueDate": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": [
        "id", "semester", "year", "studentName", "registrationId", "researchTopic",
        "topicApprovalDate", "supervisorName", "supervisorContact", "dueDate", "createdAt", "updatedAt"
      ]
    },
    "ExamManagerPaymentRecord": {
      "title": "ExamManagerPaymentRecord",
      "description": "Per course paper charge details for exam managers",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "managerId": { "type": "string" },
        "courseCode": { "type": "string" },
        "perPaperCharges": { "type": "number" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["id", "managerId", "courseCode", "perPaperCharges", "createdAt", "updatedAt"]
    },
    "F2FManager": {
      "title": "F2FManager",
      "description": "Information about Face-to-Face managers",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["id", "name", "phone", "createdAt", "updatedAt"]
    },
    "F2FCandidateRecord": {
      "title": "F2FCandidateRecord",
      "description": "Candidate registration records for Face-to-Face workshops",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "managerId": { "type": "string" },
        "semester": { "type": "string", "enum": ["Spring", "Autumn"] },
        "year": { "type": "string" },
        "serialNo": { "type": "number" },
        "candidateName": { "type": "string" },
        "fatherName": { "type": "string" },
        "contactNumber": { "type": "string" },
        "registrationId": { "type": "string" },
        "f2fCode": { "type": "string" },
        "regionalCentre": { "type": "string" },
        "paymentReceivable": { "type": "number" },
        "remarks": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": [
        "id", "managerId", "semester", "year", "serialNo", "candidateName", "fatherName",
        "contactNumber", "registrationId", "f2fCode", "regionalCentre", "paymentReceivable", "createdAt", "updatedAt"
      ]
    },
    "F2FManagerPaymentRecord": {
      "title": "F2FManagerPaymentRecord",
      "description": "Payments ledgers and histories for Face-to-Face workshop managers",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "managerId": { "type": "string" },
        "semester": { "type": "string", "enum": ["Spring", "Autumn"] },
        "year": { "type": "string" },
        "codeRates": { "type": "array" },
        "grandTotalPayable": { "type": "number" },
        "paymentsList": { "type": "array" },
        "totalPaidAmount": { "type": "number" },
        "remainingPayable": { "type": "number" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": [
        "id", "managerId", "semester", "year", "codeRates", "grandTotalPayable", "paymentsList", "totalPaidAmount", "remainingPayable", "createdAt", "updatedAt"
      ]
    }
  },
  "firestore": {
    "/students_records/{studentId}": {
      "schema": "StudentRecord",
      "description": "Collection storing student profiles, registration numbers, academic logs, and accounts"
    },
    "/exam_managers/{managerId}": {
      "schema": "ExamManager",
      "description": "Collection storing details of exam managers assigned to centres"
    },
    "/exam_records/{recordId}": {
      "schema": "StudentExamInfo",
      "description": "Collection storing examination schedules and payment logs for students"
    },
    "/degree_records/{recordId}": {
      "schema": "StudentDegreeRecord",
      "description": "Collection storing degree application information, verification logs, and dispatch states"
    },
    "/quiz_records/{recordId}": {
      "schema": "StudentQuizRecord",
      "description": "Collection storing student online quiz dates, course details, and active reminders"
    },
    "/research_project_records/{recordId}": {
      "schema": "ResearchProjectRecord",
      "description": "Collection storing student research project registration records and supervisors"
    },
    "/exam_manager_payments/{recordId}": {
      "schema": "ExamManagerPaymentRecord",
      "description": "Collection storing per course paper charge details for exam managers"
    },
    "/f2f_managers/{managerId}": {
      "schema": "F2FManager",
      "description": "Collection storing details of Face-to-Face workshop managers"
    },
    "/f2f_candidates/{recordId}": {
      "schema": "F2FCandidateRecord",
      "description": "Collection storing candidate records for Face-to-Face workshops"
    },
    "/f2f_manager_payments/{recordId}": {
      "schema": "F2FManagerPaymentRecord",
      "description": "Collection storing payment histories and code payment rate structures for F2F managers"
    }
  }
}

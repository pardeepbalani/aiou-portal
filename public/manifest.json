{
  "name": "AIOU Students Record Portal",
  "short_name": "AIOU Portal",
  "description": "An enrollment and management record system for Allama Iqbal Open University students.",
  "id": "/",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "display_override": [
    "tabbed",
    "window-controls-overlay",
    "standalone",
    "minimal-ui",
    "browser"
  ],
  "background_color": "#ffffff",
  "theme_color": "#10b981",
  "orientation": "any",
  "categories": [
    "education",
    "utilities"
  ],
  "lang": "en",
  "dir": "ltr",
  "iarc_rating_id": "e933458b-967c-47fc-8f64-9fcb06368d14",
  "prefer_related_applications": false,
  "related_applications": [
    {
      "platform": "play",
      "url": "https://play.google.com/store/apps/details?id=com.aiou.portal",
      "id": "com.aiou.portal"
    }
  ],
  "scope_extensions": [
    {
      "origin": "https://aiou-portal-taupe.vercel.app",
      "has_origin_wildcard": true
    },
    {
      "origin": "https://vercel.app",
      "has_origin_wildcard": true
    },
    {
      "origin": "https://run.app",
      "has_origin_wildcard": true
    },
    {
      "origin": "https://asia-southeast1.run.app",
      "has_origin_wildcard": true
    }
  ],
  "scopeExtensions": [
    {
      "origin": "https://aiou-portal-taupe.vercel.app",
      "has_origin_wildcard": true
    },
    {
      "origin": "https://vercel.app",
      "has_origin_wildcard": true
    },
    {
      "origin": "https://run.app",
      "has_origin_wildcard": true
    },
    {
      "origin": "https://asia-southeast1.run.app",
      "has_origin_wildcard": true
    }
  ],
  "launch_handler": {
    "client_mode": "focus-existing"
  },
  "share_target": {
    "action": "/?share=true",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "file_handlers": [
    {
      "action": "/?file=true",
      "accept": {
        "text/csv": [".csv"],
        "application/json": [".json"]
      },
      "icons": [
        {
          "src": "/app_icon_192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ],
      "launch_type": "single-client"
    }
  ],
  "protocol_handlers": [
    {
      "protocol": "web+aiou",
      "url": "/?protocol=%s"
    }
  ],
  "icons": [
    {
      "src": "/app_icon_192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/app_icon_512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/app_icon_maskable.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "/app_icon_maskable_512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "screenshots": [
    {
      "src": "/screenshot_desktop.png",
      "sizes": "1280x720",
      "type": "image/png",
      "form_factor": "wide",
      "label": "AIOU Portal Desktop Dashboard"
    },
    {
      "src": "/screenshot_mobile.png",
      "sizes": "720x1280",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "AIOU Portal Mobile Dashboard"
    }
  ],
  "shortcuts": [
    {
      "name": "Add Student Record",
      "short_name": "Add Student",
      "url": "/?shortcut=admission",
      "description": "Fast admission form for enrollment.",
      "icons": [
        {
          "src": "/app_icon_192.png",
          "sizes": "192x192",
          "type": "image/png",
          "purpose": "any"
        }
      ]
    },
    {
      "name": "View Student Database",
      "short_name": "Database",
      "url": "/?shortcut=database",
      "description": "View all students profile database.",
      "icons": [
        {
          "src": "/app_icon_192.png",
          "sizes": "192x192",
          "type": "image/png",
          "purpose": "any"
        }
      ]
    }
  ],
  "edge_side_panel": {
    "preferred_width": 480
  },
  "widgets": [
    {
      "name": "Students Record Summary",
      "short_name": "Students Record",
      "description": "Quickly check administrative statistics from Allama Iqbal Open University.",
      "tag": "aiou-stats",
      "ms_ac_template": "/widget-template.json",
      "data": "/widget-data.json",
      "icons": [
        {
          "src": "/app_icon_192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ],
      "screenshots": [
        {
          "src": "/screenshot_mobile.png",
          "sizes": "720x1280",
          "type": "image/png",
          "label": "Stats Widget"
        }
      ]
    }
  ],
  "note_taking": {
    "new_note_url": "/?shortcut=admission"
  },
  "tab_strip": {
    "home_tab": {
      "scope_patterns": [
        {
          "pathname": "/"
        }
      ],
      "icons": [
        {
          "src": "/app_icon_192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    },
    "new_tab_button": {
      "url": "/?shortcut=admission"
    }
  }
}
